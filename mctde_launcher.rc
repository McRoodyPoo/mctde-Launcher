#include "resource.h"

// The first icon resource (lowest ID) becomes the exe's Explorer/taskbar icon.
IDI_APPICON ICON "mctde.ico"

// Trimmed white-on-black Artorias silhouette, drawn themed (inverted in light mode).
IDB_ARTORIAS BITMAP "artorias.bmp"

// Changelogs embedded as raw text so the launcher stays self-contained.
IDR_CHANGELOG_LAUNCHER  RCDATA "CHANGELOG.md"
IDR_CHANGELOG_MCTDELINK RCDATA "mctde-Link.CHANGELOG.md"
